<Window x:Class="YoloDetector.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:YoloDetector.Wpf.Controls"
        Title="YOLOv5 OpenVINO Detector"
        Width="1180"
        Height="800"
        MinWidth="920"
        MinHeight="650"
        Background="#10141C"
        Foreground="#F3F6FA">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#2D6CDF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#202735"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#39445A"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="4,0,4,14"
                   FontSize="25"
                   FontWeight="SemiBold"
                   Text="YOLOv5 OpenVINO Detector"/>

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Padding="10"
                Background="#171D28"
                BorderBrush="#39445A"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="4" VerticalAlignment="Center" Text="Device"/>
                    <ComboBox ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"/>
                </StackPanel>
                <TextBox Grid.Column="1"
                         Text="{Binding ModelPath, Mode=OneWay}"
                         ToolTip="현재 OpenVINO XML 모델"/>
                <Button Grid.Column="2"
                        Command="{Binding LoadModelCommand}"
                        Content="모델 로드"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" Background="#10141C" BorderBrush="#39445A">
            <TabItem Header="Single Image Prediction">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ImagePath, Mode=OneWay}"
                                 ToolTip="추론할 단일 이미지"/>
                        <Button Grid.Column="1"
                                Command="{Binding LoadImageCommand}"
                                Content="이미지 로드"/>
                        <Button Grid.Column="2"
                                Command="{Binding DetectCommand}"
                                Background="#168C65"
                                FontWeight="Bold"
                                Content="추론"/>
                    </Grid>
                    <Border Grid.Row="1"
                            BorderBrush="#3A4559"
                            BorderThickness="1"
                            Background="#090C12"
                            CornerRadius="4">
                        <Grid ClipToBounds="True">
                            <Image Source="{Binding SourceImage}" Stretch="Uniform"/>
                            <controls:DetectionOverlay
                                Detections="{Binding Detections}"
                                ImageWidth="{Binding SourceImage.PixelWidth}"
                                ImageHeight="{Binding SourceImage.PixelHeight}"
                                IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Benchmark">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ValidationImageFolder, Mode=OneWay}"
                                 ToolTip="COCO128 루트 폴더를 선택하세요"/>
                        <Button Grid.Column="1"
                                Command="{Binding SelectValidationFolderCommand}"
                                Content="폴더 선택"/>
                        <Button Grid.Column="2"
                                Command="{Binding ValidateFolderCommand}"
                                Background="#C06A30"
                                FontWeight="Bold"
                                Content="Benchmark 실행"/>
                    </Grid>
                    <Border Grid.Row="1"
                            BorderBrush="#3A4559"
                            BorderThickness="1"
                            Background="#090C12"
                            CornerRadius="4">
                        <Grid ClipToBounds="True">
                            <Image Source="{Binding SourceImage}" Stretch="Uniform"/>
                            <controls:DetectionOverlay
                                Detections="{Binding Detections}"
                                ImageWidth="{Binding SourceImage.PixelWidth}"
                                ImageHeight="{Binding SourceImage.PixelHeight}"
                                IsHitTestVisible="False"/>
                            <Border VerticalAlignment="Bottom"
                                    Padding="12,8"
                                    Background="#CC171D28"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <ProgressBar Height="6" IsIndeterminate="True"/>
                                    <TextBlock Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               Text="{Binding Status}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3" Margin="4,12,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#AAB5C8"
                       Text="{Binding Status}"/>
            <TextBlock Grid.Column="1"
                       Margin="18,0,4,0"
                       VerticalAlignment="Center"
                       Text="Latency"/>
            <TextBlock Grid.Column="2"
                       MinWidth="100"
                       FontSize="17"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Text="{Binding LatencyText}"/>
            <TextBlock Grid.Column="3"
                       MinWidth="105"
                       FontSize="17"
                       FontWeight="Bold"
                       Foreground="#56D6A1"
                       VerticalAlignment="Center"
                       Text="{Binding FpsText}"/>
        </Grid>
    </Grid>
</Window>
